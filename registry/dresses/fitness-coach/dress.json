{
  "id": "fitness-coach",
  "name": "Fitness Coach",
  "version": "2.0.0",
  "description": "Sends workout schedule and collects post-training feedback.",

  "requires": {
    "lingerie": ["waclaw"]
  },

  "crons": [
    {
      "id": "workout-schedule",
      "name": "Daily workout schedule",
      "skill": "workout-schedule",
      "defaults": {
        "time": "18:00",
        "days": ["mon", "tue", "wed", "thu", "fri"]
      }
    },
    {
      "id": "workout-feedback",
      "name": "Post-workout check-in",
      "skill": "workout-feedback",
      "defaults": {
        "time": "20:00",
        "days": ["mon", "tue", "wed", "thu", "fri"]
      }
    }
  ],

  "skills": {
    "workout-schedule": {},
    "workout-feedback": {}
  },

  "memory": { "dailySections": ["Fitness"] },

  "heartbeat": [
    "If it is near workout time and no schedule has been sent today, nudge via WhatsApp."
  ]
}
