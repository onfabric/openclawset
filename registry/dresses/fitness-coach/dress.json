{
  "id": "fitness-coach",
  "name": "Fitness Coach",
  "version": "2.0.0",
  "description": "Sends workout schedule and collects post-training feedback.",

  "requires": {
    "lingerie": ["waclaw"]
  },

  "crons": [
    {
      "id": "workout-schedule",
      "name": "Daily workout schedule",
      "defaults": {
        "time": "18:00",
        "days": ["mon", "tue", "wed", "thu", "fri"]
      }
    },
    {
      "id": "workout-feedback",
      "name": "Post-workout check-in",
      "defaults": {
        "time": "20:00",
        "days": ["mon", "tue", "wed", "thu", "fri"]
      }
    }
  ],

  "skills": {
    "workout-schedule": {
      "trigger": { "type": "cron", "cronId": "workout-schedule" }
    },
    "workout-feedback": {
      "trigger": { "type": "cron", "cronId": "workout-feedback" }
    },
    "workout-nudge": {
      "trigger": {
        "type": "heartbeat",
        "description": "If near workout time and no schedule sent today, nudge via WhatsApp"
      }
    }
  },

  "memory": { "dailySections": ["Fitness"] }
}
