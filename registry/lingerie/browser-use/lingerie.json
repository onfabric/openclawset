{
  "id": "browser-use",
  "name": "Browser Use (CDP)",
  "version": "1.0.0",
  "description": "Cloud browser via CDP — connects OpenClaw to Browser Use for web browsing capabilities.",
  "plugins": [],
  "configSetup": {
    "prompts": [
      {
        "id": "apiKey",
        "description": "Browser Use API key",
        "required": true
      },
      {
        "id": "profileId",
        "description": "Browser Use profile ID (for persistent sessions)",
        "required": false
      }
    ],
    "configs": [
      { "key": "browser.enabled", "value": true },
      { "key": "browser.defaultProfile", "value": "browser-use" },
      { "key": "browser.remoteCdpTimeoutMs", "value": 3000 },
      { "key": "browser.remoteCdpHandshakeTimeoutMs", "value": 5000 },
      { "key": "browser.profiles.browser-use.color", "value": "#ff750e" },
      {
        "key": "browser.profiles.browser-use.cdpUrl",
        "value": "wss://connect.browser-use.com?apiKey={{apiKey}}&profileId={{profileId}}"
      }
    ]
  }
}
