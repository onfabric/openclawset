{
  "id": "browser-use",
  "name": "Browser Use (CDP + Agent)",
  "version": "1.1.0",
  "description": "Cloud browser via CDP and AI browser agent — connects OpenClaw to Browser Use for web browsing capabilities.",
  "plugins": [
    {
      "id": "browser-use-agent",
      "spec": "@onfabric/browser-use-plugin",
      "setupNotes": [
        "Uses the same Browser Use API key as the CDP connection.",
        "Get your key from https://cloud.browser-use.com/settings"
      ]
    }
  ],
  "configSetup": {
    "configs": [
      { "key": "tools.web.fetch.enabled", "value": true },
      { "key": "tools.web.search.enabled", "value": true },
      { "key": "tools.web.search.provider", "value": "duckduckgo" },
      { "key": "plugins.entries.duckduckgo.enabled", "value": true }
    ]
  },
  "toolsSection": "TOOLS.md"
}
