{
  "id": "buclaw",
  "name": "Browser (buclaw)",
  "version": "1.1.0",
  "description": "Cloud browser via AI browser agent — connects OpenClaw to Browser Use for web browsing capabilities.",
  "plugins": [
    {
      "id": "buclaw",
      "spec": "@onfabric/buclaw-plugin",
      "setupNotes": [
        "Get your API key from https://cloud.browser-use.com/settings"
      ]
    }
  ],
  "configSetup": {
    "configs": [
      { "key": "tools.web.fetch.enabled", "value": true },
      { "key": "tools.web.search.enabled", "value": true },
      { "key": "tools.web.search.provider", "value": "exa" },
      { "key": "plugins.entries.exa.enabled", "value": true }
    ]
  },
  "configPrefix": "plugins.entries.exa.config.webSearch",
  "properties": {
    "apiKey": {
      "description": "Exa AI API key",
      "required": true
    }
  },
  "toolsSection": "TOOLS.md",
  "resources": [
    "platforms/INDEX.md",
    "platforms/opentable.md"
  ]
}
