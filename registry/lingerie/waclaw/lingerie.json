{
  "id": "waclaw",
  "name": "WhatsApp (waclaw)",
  "version": "1.0.0",
  "description": "WhatsApp channel plugin via waclaw proxy — shared across dresses that need WhatsApp messaging.",
  "plugins": [
    {
      "id": "waclaw",
      "spec": "@onfabric/waclaw-plugin",
      "setupNotes": [
        "You will need a connector token from the waclaw admin API"
      ]
    }
  ],
  "configSetup": {
    "configs": [
      { "key": "tools.media.audio.enabled", "value": true },
      {
        "key": "tools.media.audio.models",
        "value": "[{\"provider\":\"openai\",\"model\":\"gpt-4o-mini-transcribe\"}]"
      },
      { "key": "messages.tts.auto", "value": "inbound" },
      { "key": "messages.tts.provider", "value": "elevenlabs" },
      { "key": "messages.tts.providers.elevenlabs.baseUrl", "value": "https://api.elevenlabs.io" },
      { "key": "messages.tts.providers.elevenlabs.modelId", "value": "eleven_v3" },
      { "key": "messages.tts.providers.elevenlabs.voiceSettings.speed", "value": 2.0 }
    ],
    "configPrefix": "messages.tts.providers.elevenlabs",
    "properties": {
      "voiceId": {
        "description": "ElevenLabs Voice Id (default: Jessica)",
        "required": true,
        "default": "flHkNRp1BlvT73UL6gyz"
      },
      "apiKey": {
        "description": "ElevenLabs API key",
        "required": true
      }
    }
  }
}
