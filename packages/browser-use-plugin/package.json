{
  "name": "@onfabric/buclaw-plugin",
  "description": "Browser Use Agent for OpenClaw — delegate browser tasks to an AI agent",
  "version": "0.0.3",
  "license": "MIT",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/*",
    "package.json",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist/ --external openclaw  --target node"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.29"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@sinclair/typebox": "^0.34.48",
    "browser-use-sdk": "==3.4.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
