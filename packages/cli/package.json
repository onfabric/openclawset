{
  "name": "@clawtique/cli",
  "version": "0.1.0",
  "description": "Goal-oriented wardrobe for your OpenClaw agent",
  "type": "module",
  "bin": {
    "clawtique": "./bin/run.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "check:types": "bun run --bun tsc"
  },
  "oclif": {
    "bin": "clawtique",
    "dirname": "clawtique",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " "
  },
  "dependencies": {
    "@clawtique/core": "workspace:*",
    "@inquirer/prompts": "^7.0.0",
    "@oclif/core": "^4.0.0",
    "chalk": "^5.4.0",
    "json5": "^2.2.0",
    "listr2": "^8.0.0",
    "ora": "^8.0.0",
    "proper-lockfile": "^4.1.0",
    "simple-git": "^3.27.0",
    "write-file-atomic": "^6.0.0"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^6.0.0",
    "@repo/typescript-config": "workspace:*",
    "@types/proper-lockfile": "^4.1.4",
    "@types/write-file-atomic": "^4.0.3",
    "typescript": "^5.7.0"
  }
}
